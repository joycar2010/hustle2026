# Database (managed by deploy; do not commit real creds)
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=CHANGE_ME

# OpenCLAW LLM relay (Anthropic/OpenAI compatible new-api fork)
OPENCLAW_LLM_BASE_URL=http://<relay-host>:3000
OPENCLAW_LLM_API_KEY=sk-...
OPENCLAW_LLM_MODEL=gpt-5
OPENCLAW_LLM_PROTOCOL=openai
