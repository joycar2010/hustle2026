<!-- works.wxml -->
<navigation-bar title="作品展示" back="{{false}}" color="black" background="#FFF"></navigation-bar>
<scroll-view class="scrollarea" scroll-y type="list">
  <view class="container">
    <!-- 筛选栏 -->
    <view class="filter-bar">
      <view class="filter-item {{currentType === 'all' ? 'active' : ''}}" bindtap="switchType" data-type="all">全部</view>
      <view class="filter-item {{currentType === 'residential' ? 'active' : ''}}" bindtap="switchType" data-type="residential">家装设计</view>
      <view class="filter-item {{currentType === 'office' ? 'active' : ''}}" bindtap="switchType" data-type="office">公装设计</view>
      <view class="filter-item {{currentType === 'commercial' ? 'active' : ''}}" bindtap="switchType" data-type="commercial">商业空间</view>
    </view>
    
    <!-- 作品列表 -->
    <view class="works-grid">
      <block wx:for="{{filteredWorks}}" wx:key="id" wx:for-item="work">
        <navigator url="/pages/work-detail/work-detail?id={{work.id}}" class="work-item">
          <image src="{{work.coverImage}}" mode="aspectFill"></image>
          <view class="work-info">
            <view class="work-title">{{work.title}}</view>
            <view class="work-meta">{{work.spaceType}} | {{work.area}}㎡</view>
          </view>
        </navigator>
      </block>
    </view>
    
    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore}}">
      <text>加载更多...</text>
    </view>
  </view>
</scroll-view>