<!-- works.wxml -->
<navigation-bar title="作品展示" back="{{false}}" color="white" background="#1A2430"></navigation-bar>

<!-- 筛选栏 -->
<view class="filter-bar">
  <view class="filter-item {{filterType === '' ? 'active' : ''}}" bindtap="setFilterType" data-type="">全部</view>
  <view class="filter-item {{filterType === 'residential' ? 'active' : ''}}" bindtap="setFilterType" data-type="residential">家装设计</view>
  <view class="filter-item {{filterType === 'office' ? 'active' : ''}}" bindtap="setFilterType" data-type="office">公装设计</view>
  <view class="filter-item {{filterType === 'commercial' ? 'active' : ''}}" bindtap="setFilterType" data-type="commercial">商业空间</view>
</view>

<scroll-view class="scrollarea" scroll-y type="list" style="background-color: #1A2430;">
  <view class="container">
    <!-- 作品列表 -->
    <view class="works-grid">
      <block wx:for="{{worksList}}" wx:key="id" wx:for-item="work">
        <navigator url="/pages/work-detail/work-detail?id={{work.id}}" class="work-item">
          <view class="work-card">
            <view class="work-image-container">
              <image src="{{work.coverImage}}" mode="aspectFill" class="work-image"></image>
              <view class="work-number">
                <text class="work-number-text">0{{index + 1}}</text>
              </view>
            </view>
            <view class="work-content">
              <view class="work-title">{{work.title}}</view>
              <view class="work-subtitle">{{work.description || '融合现代美学与实用功能的空间设计'}}</view>
              <view class="work-meta">
                <view class="meta-item">
                  <view class="meta-label">项目面积</view>
                  <view class="meta-value">{{work.area}} ㎡</view>
                </view>
                <view class="meta-item">
                  <view class="meta-label">项目地点</view>
                  <view class="meta-value">{{work.location || '未知'}}</view>
                </view>
                <view class="meta-item">
                  <view class="meta-label">设计风格</view>
                  <view class="meta-value">{{work.style || '现代简约'}}</view>
                </view>
              </view>
            </view>
          </view>
        </navigator>
      </block>
    </view>
    
    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore}}">
      <text>加载更多...</text>
    </view>
    
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{worksList.length === 0 && !loading}}">
      <view class="empty-icon">📷</view>
      <view class="empty-title">暂无作品</view>
      <view class="empty-subtitle">请稍后再试</view>
    </view>
  </view>
</scroll-view>