<!-- 自定义导航栏 -->
<page-meta>
  <navigation-bar title="关于我们" show-back="true"></navigation-bar>
</page-meta>

<!-- 品牌页面 -->
<view class="brand-section">
  <!-- 品牌图片 -->
  <view class="brand-image-container">
    <image class="brand-image" src="{{brandInfo.logo}}" mode="aspectFit"></image>
  </view>
  
  <!-- 品牌介绍 -->
  <view class="section">
    <view class="section-title">{{brandInfo.name}}</view>
    <view class="brand-intro">
      <text class="intro-text">{{brandInfo.description}}</text>
    </view>
  </view>
  
  <!-- 我们的成就 -->
  <view class="section">
    <view class="section-subtitle">我们的成就</view>
    <view class="achievements-grid">
      <view class="achievement-item">
        <text class="achievement-number">{{achievements.designers}}</text>
        <text class="achievement-label">专业设计师</text>
      </view>
      <view class="achievement-item">
        <text class="achievement-number">{{achievements.suppliers}}</text>
        <text class="achievement-label">合作供应商</text>
      </view>
      <view class="achievement-item">
        <text class="achievement-number">{{achievements.projects}}</text>
        <text class="achievement-label">完成项目</text>
      </view>
      <view class="achievement-item">
        <text class="achievement-number">{{achievements.awards}}</text>
        <text class="achievement-label">行业奖项</text>
      </view>
    </view>
  </view>
  
  <!-- 设计理念 -->
  <view class="section">
    <view class="section-subtitle">设计理念</view>
    <view class="concept-list">
      <view wx:for="{{concepts}}" wx:key="id" class="concept-item">
        <view class="concept-number">{{item.id < 10 ? '0' + item.id : item.id}}</view>
        <view class="concept-content">
          <text class="concept-title">{{item.title}}</text>
          <text class="concept-desc">{{item.description}}</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 设计流程 -->
  <view class="section">
    <view class="section-subtitle">设计流程</view>
    <view class="process-list">
      <view wx:for="{{process}}" wx:key="id" class="process-item">
        <view class="process-number">{{item.id < 10 ? '0' + item.id : item.id}}</view>
        <view class="process-content">
          <text class="process-title">{{item.title}}</text>
          <text class="process-desc">{{item.description}}</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 核心团队 -->
  <view class="section">
    <view class="section-title">核心团队</view>
    <view class="team-list">
      <view wx:for="{{team}}" wx:key="id" class="team-item">
        <view class="team-info">
          <text class="team-name">{{item.name}}</text>
          <text class="team-position">{{item.position}}</text>
        </view>
        <view class="team-image-container">
          <image class="team-image" src="{{item.image}}" mode="aspectFill"></image>
        </view>
      </view>
    </view>
  </view>

  <!-- 资质荣誉 -->
  <view class="section">
    <view class="section-title">资质荣誉</view>
    <view class="honor-list">
      <view wx:for="{{honors}}" wx:key="id" class="honor-item">
        <view class="honor-icon">{{item.icon}}</view>
        <view class="honor-content">
          <text class="honor-title">{{item.title}}</text>
          <text class="honor-desc">{{item.description}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 公司照片 -->
  <view class="section" wx:if="{{companyPhotos && companyPhotos.length > 0}}">
    <view class="section-title">公司风采</view>
    <view class="photos-grid">
      <view wx:for="{{companyPhotos}}" wx:key="id" class="photo-item">
        <image src="{{item.url}}" mode="aspectFit" class="photo-image"></image>
        <view class="photo-description" wx:if="{{item.description}}">{{item.description}}</view>
      </view>
    </view>
  </view>

  <!-- 合作伙伴 -->
  <view class="section">
    <view class="section-title">合作伙伴</view>
    <view class="partner-desc">
      {{partners.description}}
    </view>
    <view class="partner-grid">
      <view wx:for="{{partners.list}}" wx:key="index" class="partner-item">
        <image wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFit" class="partner-image"></image>
        <view wx:else>
          {{item.name || item}}
        </view>
      </view>
    </view>
  </view>

  <!-- 合作咨询 -->
  <view class="cooperation-section">
    <view class="cooperation-title">{{cooperation.title}}</view>
    <view class="cooperation-desc">
      {{cooperation.description}}
    </view>
    <view class="cooperation-cta" bindtap="goToContact">
      在线咨询
    </view>
  </view>

  <!-- 版权信息 -->
  <view class="copyright-section">
    <text class="copyright-text">© 2026 {{brandInfo.name}}</text>
  </view>
</view>