<!-- brand.wxml -->
<navigation-bar title="关于我们" back="{{false}}" color="black" background="#FFF"></navigation-bar>
<scroll-view class="scrollarea" scroll-y type="list">
  <view class="container">
    <!-- 品牌LOGO和名称 -->
    <view class="brand-header">
      <image src="/images/logo.png" mode="aspectFit"></image>
      <view class="brand-name">布珥·迈拓空间设计</view>
      <view class="brand-slogan">用设计定义高端空间美学</view>
    </view>
    
    <!-- 公司简介 -->
    <view class="section">
      <view class="section-title">公司简介</view>
      <view class="section-content">
        <text class="content-text">布珥·迈拓空间设计是一家专注于高端空间设计的专业机构，致力于为客户提供从概念设计到施工落地的全方位服务。我们的设计团队由经验丰富的设计师组成，擅长各种风格的空间设计，包括现代简约、轻奢、中式、美式等。</text>
        <text class="content-text">我们坚持以客户需求为中心，结合空间特点和设计美学，创造出既实用又美观的空间解决方案。我们的作品涵盖了住宅、办公、商业等多种空间类型，赢得了客户的广泛认可和好评。</text>
      </view>
    </view>
    
    <!-- 设计理念 -->
    <view class="section">
      <view class="section-title">设计理念</view>
      <view class="concept-list">
        <view class="concept-item">
          <view class="concept-icon">🎯</view>
          <view class="concept-content">
            <view class="concept-title">以人为本</view>
            <view class="concept-desc">设计源于生活，服务于生活，注重人的体验和感受</view>
          </view>
        </view>
        <view class="concept-item">
          <view class="concept-icon">💎</view>
          <view class="concept-content">
            <view class="concept-title">品质至上</view>
            <view class="concept-desc">追求卓越品质，注重细节，精益求精</view>
          </view>
        </view>
        <view class="concept-item">
          <view class="concept-icon">✨</view>
          <view class="concept-content">
            <view class="concept-title">创新设计</view>
            <view class="concept-desc">不断探索新的设计理念和方法，保持设计的新鲜感和创新性</view>
          </view>
        </view>
        <view class="concept-item">
          <view class="concept-icon">🤝</view>
          <view class="concept-content">
            <view class="concept-title">合作共赢</view>
            <view class="concept-desc">与客户建立长期合作关系，实现共赢发展</view>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 团队介绍 -->
    <view class="section">
      <view class="section-title">设计团队</view>
      <view class="team-intro">
        <text class="content-text">我们拥有一支专业的设计团队，团队成员均具有丰富的设计经验和专业背景。我们注重团队协作，充分发挥每个人的优势，为客户提供最优质的设计服务。</text>
        <text class="content-text">我们的设计师不仅具有扎实的专业知识，还具备良好的沟通能力和服务意识，能够深入理解客户需求，提供个性化的设计解决方案。</text>
      </view>
    </view>
    
    <!-- 联系信息 -->
    <view class="section">
      <view class="section-title">联系我们</view>
      <view class="contact-info">
        <view class="contact-item">
          <view class="contact-label">电话</view>
          <view class="contact-value">400-123-4567</view>
        </view>
        <view class="contact-item">
          <view class="contact-label">邮箱</view>
          <view class="contact-value">info@boolean-mustang.com</view>
        </view>
        <view class="contact-item">
          <view class="contact-label">地址</view>
          <view class="contact-value">上海市浦东新区陆家嘴金融中心88号</view>
        </view>
      </view>
    </view>
  </view>
</scroll-view>