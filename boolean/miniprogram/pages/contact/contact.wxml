<!-- 自定义导航栏 -->
<page-meta>
  <navigation-bar title="联系我们" show-back="true"></navigation-bar>
</page-meta>

<!-- 联系页面 -->
<view class="contact-section">
  <!-- 联系标题 -->
  <view class="section">
    <view class="section-title">联系我们</view>
    <view class="section-subtitle">准备开启您的设计之旅？联系我们的设计团队</view>
  </view>
  
  <!-- 联系信息 -->
  <view class="contact-info">
    <view class="info-grid">
      <view class="info-item">
        <text class="info-label">电话</text>
        <text class="info-value info-link" bindtap="makePhoneCall">{{contactInfo.phone}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">邮箱</text>
        <text class="info-value info-link" bindtap="sendEmail">{{contactInfo.email}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">温州办公地址</text>
        <text class="info-value info-link" bindtap="openMap1">{{contactInfo.address1}}</text>
      </view>
      <view class="info-item" wx:if="{{contactInfo.address2}}">
        <text class="info-label">杭州办公地址</text>
        <text class="info-value info-link" bindtap="openMap2">{{contactInfo.address2}}</text>
      </view>
      <view class="info-item info-item-wide">
        <text class="info-label">营业时间</text>
        <text class="info-value">{{contactInfo.workingHours}}</text>
      </view>
    </view>
  </view>
  
  <!-- 联系表单 -->
  <view class="contact-form">
    <view class="form-title">在线咨询</view>
    <form bindsubmit="submitForm">
      <view class="form-item">
        <input class="form-input" name="name" placeholder="您的姓名" placeholder-class="placeholder" required></input>
      </view>
      <view class="form-item">
        <input class="form-input" name="phone" placeholder="联系电话" placeholder-class="placeholder" required></input>
      </view>
      <view class="form-item">
        <input class="form-input" name="email" placeholder="电子邮箱" placeholder-class="placeholder" type="email"></input>
      </view>
      <view class="form-item">
        <picker class="form-picker" name="projectType" range="{{categories}}" range-key="name" bindchange="onProjectTypeChange">
          <view class="picker-content">
            {{selectedCategory || '请选择项目类型'}}
          </view>
        </picker>
      </view>
      <view class="form-item">
        <input class="form-input" name="budget" placeholder="预算范围" placeholder-class="placeholder"></input>
      </view>
      <view class="form-item">
        <textarea class="form-textarea" name="message" placeholder="您的需求" placeholder-class="placeholder" required></textarea>
      </view>
      <button class="submit-btn" form-type="submit">提交咨询</button>
    </form>
  </view>
  

</view>
